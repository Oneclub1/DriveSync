generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String   // INSTRUCTOR or LEARNER
  phoneNumber  String?
  createdAt    DateTime @default(now())
  isActive     Boolean  @default(true)

  // Instructor-spezifische Settings (override global config)
  cancellationDeadlineHours Int?
  maxBookingsPerWeek        Int?
  reminderHoursBefore       Int?    @default(24)
  emailNotifications        Boolean @default(true)

  // Push subscription (Web Push)
  pushSubscription String?

  students     InstructorLearner[] @relation("InstructorStudents")
  instructors  InstructorLearner[] @relation("LearnerInstructors")
  timeSlots    TimeSlot[]
  bookings     Booking[]
  invitations  Invitation[]
  notifications Notification[]
}

model InstructorLearner {
  instructorId String
  learnerId    String
  assignedAt   DateTime @default(now())

  instructor   User @relation("InstructorStudents", fields: [instructorId], references: [id])
  learner      User @relation("LearnerInstructors", fields: [learnerId], references: [id])

  @@id([instructorId, learnerId])
}

model TimeSlot {
  id           String   @id @default(uuid())
  instructorId String
  startTime    DateTime
  endTime      DateTime
  isAvailable  Boolean  @default(true)
  slotType     String   @default("LESSON")
  createdAt    DateTime @default(now())

  instructor   User     @relation(fields: [instructorId], references: [id])
  booking      Booking?
}

model Booking {
  id              String    @id @default(uuid())
  learnerId       String
  timeSlotId      String    @unique
  status          String    @default("PENDING")
  bookedAt        DateTime  @default(now())
  cancelledAt     DateTime?
  cancellationFee Boolean   @default(false)
  notes           String?

  // Reminder-Tracking
  reminderSentAt  DateTime?

  // Zahlung
  paymentStatus   String?   // null, "PENDING", "PAID", "FAILED"
  paymentAmount   Float?    // in EUR
  paymentRef      String?   // Stripe Charge/Intent ID

  learner         User     @relation(fields: [learnerId], references: [id])
  timeSlot        TimeSlot @relation(fields: [timeSlotId], references: [id])
}

model Invitation {
  id           String    @id @default(uuid())
  instructorId String
  email        String
  token        String    @unique
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  acceptedAt   DateTime?
  isUsed       Boolean   @default(false)

  instructor   User @relation(fields: [instructorId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // BOOKING_CREATED, BOOKING_CANCELLED, BOOKING_CONFIRMED, REMINDER, etc.
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Optional: Verknüpfung zu Buchung
  bookingId String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
}
